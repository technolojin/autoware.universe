<launch>
  <!-- Ports -->
  <arg name="input/rois" default="/perception/object_recognition/detection/rois0"/>
  <arg name="input/camera_info" default="/sensing/camera/camera0/camera_info"/>
  <arg name="output_frame_id" default="base_link"/>
  <arg name="output/roi_object" default="output/objects"/>
  <!-- Node -->
  <node pkg="vision_roi_object_detector" exec="vision_roi_object_detector_node" name="roi_object_detector" output="screen">
    <remap from="input/rois" to="$(var input/rois)"/>
    <remap from="input/camera_info" to="$(var input/camera_info)"/>
    <remap from="~/output/roi_object" to="$(var output/roi_object)"/>
    <param name="output_frame_id" value="$(var output_frame_id)"/>
  </node>
</launch>
